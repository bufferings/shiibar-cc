<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Time-sensitive notifications for waiting alerts (DESIGN.md §4.5:
	     interruption level time-sensitive so waiting toasts show through
	     Focus/DND). Whether a locally-signed (non-notarized) app is granted
	     this is a device-smoke question; it must at least be requested. -->
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
</dict>
</plist>
